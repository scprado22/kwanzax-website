function ServicoDetalhe() {
  const { slug } = useParams();
  const svc = DATA.services.find(s => s.slug === slug);
  const nav = useNavigate();
  if (!svc) return (
    <section className="py-20"><Container><p>Serviço não encontrado.</p></Container></section>
  );
  const Icon = svc.icon;
  return (
    <section className="py-20">
      <Container>
        <button onClick={()=> nav(-1)} className="text-white/60 hover:text-white inline-flex items-center gap-2 transition-colors"><ArrowLeft className="h-4 w-4"/> Voltar</button>
        <div className="mt-4 flex items-center gap-3"><Icon className="h-6 w-6 text-amber-300"/><h1 className="text-3xl font-semibold">{svc.title}</h1></div>
        <p className="mt-3 text-white/70 max-w-3xl">{svc.summary}</p>
        <div className="mt-6 grid md:grid-cols-2 gap-6">
          <Card className="bg-white/5 border-white/10"><CardHeader><CardTitle>O que entregamos</CardTitle></CardHeader><CardContent className="text-sm text-white/70 space-y-2">{svc.bullets.map((b,i)=>(<p key={i}>• {b}</p>))}</CardContent></Card>
          <Card className="bg-white/5 border-white/10"><CardHeader><CardTitle>KPIs & Resultados</CardTitle></CardHeader><CardContent className="text-sm text-white/70 space-y-2"><p>Tempo de implementação</p><p>ROI/deflexão de tickets</p><p>Uptime e SLOs</p><p>NPS dos utilizadores</p></CardContent></Card>
        </div>
      </Container>
    </section>
  );
}

